# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Apify
APIFY_API_TOKEN=apify_api_...

# Scheduler - 24hr format, what time daily run fires
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0

# Filtering threshold - memes scoring below this are auto-dropped (0-10)
AI_SCORE_THRESHOLD=5.0

# How many posts to pull per hashtag per platform per run
POSTS_PER_HASHTAG=30

# Hashtags to monitor (comma separated, no # symbol)
INSTAGRAM_HASHTAGS=patchgore,moralepatches,edc,patchjunkie,gunmemes,militarymemes,tacticalhumor,2amemes
TIKTOK_HASHTAGS=patchgore,militarymemes,gunmemes,tacticalhumor,2amemes

# Reddit subreddits (comma separated, no r/ prefix)
REDDIT_SUBREDDITS=PatchGore,MoralePatches,militarymemes,guns,tacticalgear
